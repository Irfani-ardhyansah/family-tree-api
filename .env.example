# Server
PORT=3000
NODE_ENV=development

# Database (Knex / mysql2)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=family_tree
# DSN equivalent: mysql://root@localhost:3306/family_tree

# CORS — comma-separated FE origins (no spaces required)
# Development: * allows any origin (credentials OK via reflect)
# Production: MUST be explicit, e.g. http://localhost:5173,https://familyroots.app
CORS_ORIGINS=*

# Auth — JWT + refresh (Part 3+)
JWT_SECRET=change-me-in-production-min-32-chars-dev
ACCESS_TTL=3600
REFRESH_TTL_REMEMBER=2592000
REFRESH_TTL_SESSION=86400

# Login rate limit (Part 3)
LOGIN_RATE_LIMIT_MAX=10
LOGIN_RATE_LIMIT_WINDOW_MS=900000
